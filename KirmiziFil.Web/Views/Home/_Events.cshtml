@model KirmiziFil.Web.ViewModels.EventsViewModel

@{
    var colorClasses = new[] { "event-card--red", "event-card--green", "event-card--yellow", "event-card--blue" };
}

<section class="events">

    <div class="container">

        <div class="events__header">

            <h2 class="events__title">Yaklaşan Etkinlikler</h2>

            <a href="@Model.AllEventsUrl" class="events__link">
                Tümünü Gör →
            </a>

        </div>

        <div class="events__list">

            @for (int i = 0; i < Model.Events.Count; i++)
            {
                var item = Model.Events[i];
                var colorClass = colorClasses[i % colorClasses.Length];

                <article class="event-card @colorClass">

                    <div class="event-card__date">
                        <span class="event-card__day">@item.Day</span>
                        <span class="event-card__month">@item.Month</span>
                    </div>

                    <div class="event-card__body">
                        <h3 class="event-card__title">@item.Title</h3>
                        <p class="event-card__meta">@item.DayOfWeek • @item.Time</p>
                    </div>

                </article>
            }

        </div>

    </div>

</section>
